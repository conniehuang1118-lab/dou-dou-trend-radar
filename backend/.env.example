APP_NAME=trend-radar-mvp
APP_HOST=0.0.0.0
APP_PORT=8080
APP_TIMEZONE=Asia/Shanghai
APP_ENV=dev
ENABLE_INTERNAL_SCHEDULER=true
SHARE_AUTH_ENABLED=false
SHARE_AUTH_USERNAME=share
SHARE_AUTH_PASSWORD=

DATABASE_URL=postgresql://trend:trend@db:5432/trend_radar

# Pipeline
PIPELINE_INTERVAL_MINUTES=5
BREAKING_GROWTH_THRESHOLD=0.40
BREAKING_MIN_SOURCE_COUNT=3
BREAKING_HOURS=6

# Optional feeds (RSSHub etc.)
ZHIHU_HOT_RSS=https://rsshub.app/zhihu/hotlist
X_TREND_RSS=https://rsshub.app/x/trending

# Optional API keys (for future real providers)
X_BEARER_TOKEN=
NEWS_API_KEY=
